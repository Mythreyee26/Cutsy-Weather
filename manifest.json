{
  "manifest_version": 3,
  "name": "Cutsy Weather",
  "short_name": "Cutsy",
  "version": "1.0.0",
  "description": "A soft, cozy, pastel kawaii weather widget that floats on every webpage. (｡•ᴗ•｡)",

  "permissions": [
    "storage",
    "geolocation"
  ],

  "host_permissions": [
    "https://api.openweathermap.org/*",
    "https://ipapi.co/*"
  ],

  "background": {
    "service_worker": "src/background/background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/content.js"],
      "css": ["src/content/widget.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Cutsy Weather 🌸",
    "default_icon": {
      "16": "src/assets/icons/icon16.png",
      "32": "src/assets/icons/icon32.png",
      "48": "src/assets/icons/icon48.png",
      "128": "src/assets/icons/icon128.png"
    }
  },

  "icons": {
    "16": "src/assets/icons/icon16.png",
    "32": "src/assets/icons/icon32.png",
    "48": "src/assets/icons/icon48.png",
    "128": "src/assets/icons/icon128.png"
  },

  "web_accessible_resources": [
    {
      "resources": ["src/assets/icons/*.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
